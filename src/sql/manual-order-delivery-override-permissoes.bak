-- Permissões seguras: somente a API com service_role pode executar.

revoke execute on function public.confirm_order_manual_delivery(
  uuid,
  uuid,
  text,
  text,
  text,
  text,
  text,
  text
) from public;

revoke execute on function public.confirm_order_manual_delivery(
  uuid,
  uuid,
  text,
  text,
  text,
  text,
  text,
  text
) from anon;

revoke execute on function public.confirm_order_manual_delivery(
  uuid,
  uuid,
  text,
  text,
  text,
  text,
  text,
  text
) from authenticated;

grant execute on function public.confirm_order_manual_delivery(
  uuid,
  uuid,
  text,
  text,
  text,
  text,
  text,
  text
) to service_role;


revoke execute on function public.revert_order_manual_delivery(
  uuid,
  uuid,
  text,
  text,
  text,
  text
) from public;

revoke execute on function public.revert_order_manual_delivery(
  uuid,
  uuid,
  text,
  text,
  text,
  text
) from anon;

revoke execute on function public.revert_order_manual_delivery(
  uuid,
  uuid,
  text,
  text,
  text,
  text
) from authenticated;

grant execute on function public.revert_order_manual_delivery(
  uuid,
  uuid,
  text,
  text,
  text,
  text
) to service_role;